  "code": "def generate_signal(context, data, symbol):\n    # Get price history\n    prices = data.history(symbol, 'close', 50)\n    \n    # Calculate SMAs\n    fast = prices[-10:].mean()\n    slow = prices[-30:].mean()\n    \n    # Get previous values\n    prices_prev = data.history(symbol, 'close', 51)[:-1]\n    fast_prev = prices_prev[-10:].mean()\n    slow_prev = prices_prev[-30:].mean()\n    \n    # Check for crossover\n    if fast_prev <= slow_prev and fast > slow:\n        return 'BUY'\n    elif fast_prev >= slow_prev and fast < slow:\n        return 'SELL'\n    return 'HOLD'\n\ndef backtest(symbols, start_date, end_date):\n    return run_backtest(\n        strategy='sma-crossover',\n        symbols=symbols,\n        start_date=start_date,\n        end_date=end_date,\n        fast_period=10,\n        slow_period=30\n    )",
